# Supabase (browser — apenas URL + anon; nunca service_role aqui)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL pública do app
VITE_PUBLIC_APP_URL=http://localhost:3000

# Sentry (error monitoring — DSN do projeto)
VITE_SENTRY_DSN=
VITE_APP_VERSION=0.0.1

# PostHog (product analytics)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Web Push (VAPID public key — segura para expor no browser)
VITE_VAPID_PUBLIC_KEY=

# Mercado Pago (Checkout Transparente — chave pública no browser)
VITE_MP_PUBLIC_KEY=

# Mercado Pago (pagamentos — apenas em Edge Functions / servidor)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
